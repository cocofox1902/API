# Copy to .env and fill in values. Never commit .env.
# Step-by-step: see SETUP_SUPABASE.md

PORT=3000

# Required for admin JWT (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-string

# Supabase: Project Settings → Database → Connection string (URI), direct connection, port 5432
# Replace YOUR_PASSWORD with your database password.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.pcdlsbbdxefuyyuilhbj.supabase.co:5432/postgres

# SSL: auto-enabled for Supabase hosts. Set to "false" to force disable (local only).
# DATABASE_SSL=

# When false, the API does not run CREATE/ALTER DDL (use supabase/migrations/001_init.sql in dashboard).
# Default: false if DATABASE_URL contains "supabase.co", otherwise true (local Postgres).
# RUN_API_DDL=true
# RUN_API_DDL=false

# Optional: later for mobile / admin calling Supabase REST (not used by Express+pg)
# SUPABASE_URL=https://pcdlsbbdxefuyyuilhbj.supabase.co
# SUPABASE_ANON_KEY=your_publishable_or_anon_key
